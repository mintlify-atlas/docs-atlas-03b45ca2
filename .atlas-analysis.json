    "@empathyco/x-adapter-platform - Empathy Platform adapter",
    "@empathyco/x-types - TypeScript types and models",
    "@empathyco/x-tailwindcss - Tailwind design system plugin",
    "@empathyco/x-utils - Utility functions",
    "@empathyco/x-archetype-utils - Archetype utilities",
    "SearchBox - Search input component",
    "Facets - Filtering component",
    "Recommendations - Product recommendations",
    "QuerySuggestions - Search suggestions",
    "HistoryQueries - Search history",
    "PopularSearches - Trending searches",
    "NextQueries - Related searches",
    "IdentifierResults - Identifier-based results",
    "Empathize - Predictive layer",
