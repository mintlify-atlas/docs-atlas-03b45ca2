  "keyFeatures": [
    "Vue.js-based component library for commerce search experiences",
    "Modular architecture with independent X Modules for different features",
    "Event-driven system for component communication",
    "Adapter pattern for connecting to any search API",
    "Built-in Tailwind CSS design system builder",
    "Search box with suggestions and predictive layer",
    "Faceted search with filters",
    "Product recommendations and discovery",
    "Query history and personalization",
    "URL state management",
    "Privacy-first tagging and analytics",
    "Accessibility support"
  ],
